# Frontend build variables. These are public client-side values.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Set to "1" to surface legacy Apify call/credit metrics in the System Health
# panel even when usage is zero. Leave unset for normal operation.
VITE_SHOW_APIFY=

# Required for smoke and benchmark scripts that read internal ops views.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Required confirmation for the destructive synthetic Phase 3 search reseed.
PHASE3_RESET_CONFIRM=ofzuhajxwxggybkuzefq
